# ICRAS Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env with real secrets.

OPENAI_API_KEY=
# Optional LangSmith tracing for LangGraph pipeline runs.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=icras-agent-h
LANGSMITH_ENDPOINT=

# Optional Jira posting integration. When these are empty, runs write a
# disabled jira_posting_result.json artifact and continue normally.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Task
